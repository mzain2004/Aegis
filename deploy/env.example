# Copy to deploy/.env before running docker compose on Alibaba Cloud ECS.
# Keep this stack small (proxy + mock MCP) on a free-trial 2c2g/2c4g instance.

ENVIRONMENT=production
LOG_LEVEL=INFO
PROXY_HOST=0.0.0.0
PROXY_PORT=9000

# Point Veto Ops at the compose MCP service (mock or real).
K8S_MCP_SERVER_URL=http://mcp:8000

# CHANGE THESE before any public exposure.
SHARED_HMAC_SECRET=replace-with-long-random-secret
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_APIKEY=replace-with-strong-admin-key
AUTH_ENABLED=true
ALLOW_ANONYMOUS_DEV=false

DATABASE_URL=sqlite:////app/data/veto-ops.db
PENDING_REQUEST_TTL_SECONDS=300
NONCE_TTL=300
EXECUTION_BACKEND=kubernetes
PROMETHEUS_ENABLED=true
METRICS_ENABLED=true
OTEL_ENABLED=false

# Qwen / DashScope (agent runs on the host or a second container)
DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max
VETO_PROXY_URL=http://127.0.0.1:9000
AGENT_TOOL_MODE=bridge
QWEN_PRESERVE_THINKING=true
QWEN_SESSION_CACHE=true
