# Qwen SafeOps agent environment example
# Copy values into your root .env (gitignored) or export them in the shell.

DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max

# Engineer 1 proxy — default local bridge target
AEGIS_PROXY_URL=http://127.0.0.1:9000

# bridge = local function tools + HTTP JSON-RPC to Aegis (recommended for local demo)
# remote_mcp = DashScope-native MCP tool (requires public SSE URL)
AGENT_TOOL_MODE=bridge

# Optional: public SSE facade in front of Aegis for AGENT_TOOL_MODE=remote_mcp
# AEGIS_MCP_SSE_URL=https://your-tunnel.example/sse

QWEN_PRESERVE_THINKING=true
QWEN_SESSION_CACHE=true
AGENT_MAX_TURNS=16
AGENT_REQUEST_TIMEOUT_SECONDS=120
AGENT_MCP_BRIDGE_TIMEOUT_SECONDS=60
AGENT_APPROVAL_WAIT_HINT_SECONDS=300
