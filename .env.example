# Network binding for the FastAPI service.
PROXY_HOST=0.0.0.0

# HTTP port exposed by uvicorn.
PROXY_PORT=9000

# Upstream Kubernetes MCP server URL used by the forwarder.
K8S_MCP_SERVER_URL=http://127.0.0.1:8000

# Shared secret reserved for future HMAC verification.
SHARED_HMAC_SECRET=development-shared-secret

# Nonce lifetime in seconds for future approval workflows.
NONCE_TTL=300

# Structured logging level.
LOG_LEVEL=INFO

# Deployment environment label.
ENVIRONMENT=development

# --- Database ---
# Database connection string for persistent storage (SQLite by default).
DATABASE_URL=sqlite:///./aegis.db

# --- Authentication & RBAC ---
# Enable operator authentication (API key + RBAC) for protected routes.
AUTH_ENABLED=true

# Allow anonymous access when auth is misconfigured; keep disabled outside local dev.
ALLOW_ANONYMOUS_DEV=false

# CHANGE THESE before any public exposure.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_APIKEY=admin-api-key-12345

# --- Execution ---
# Backend used to execute approved actions.
EXECUTION_BACKEND=kubernetes

# Timeout in seconds for a single execution attempt.
EXECUTION_TIMEOUT=10

# Number of retries attempted for a failed execution.
EXECUTION_RETRIES=0

# How long a pending (awaiting-approval) request stays valid, in seconds.
PENDING_REQUEST_TTL_SECONDS=300

# Timeout in seconds for calls to the upstream MCP server.
MCP_TIMEOUT_SECONDS=10

# --- Observability ---
# Expose Prometheus metrics.
PROMETHEUS_ENABLED=true

# Enable OpenTelemetry tracing (opt-in; disabled by default).
OTEL_ENABLED=false

# Expose the internal metrics collection/registry.
METRICS_ENABLED=true

# Enable request tracing spans/logging.
ENABLE_TRACE=true

# Number of days to retain audit log entries before cleanup.
AUDIT_RETENTION_DAYS=30

# --- Health checks ---
# Timeout in seconds for health check probes.
HEALTH_CHECK_TIMEOUT=5

# Path to the BPF-LSM kernel failsafe's plaintext audit log (read-only tail).
# FAILSAFE_AUDIT_LOG_PATH=/var/log/mcp-failsafe.log

# Transport backend the failsafe correlator delegates actual dispatch to.
# FAILSAFE_DELEGATE_BACKEND=kubernetes

# Cgroup id to filter failsafe block events by; 0 disables the filter.
# FAILSAFE_CGROUP_ID=0

# Downgrade a result to a 502 failure when the kernel blocked anything in-window.
# FAILSAFE_FAIL_ON_BLOCK=false

# --- Qwen SafeOps agent (Engineer 2) ---
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3.7-max
# AEGIS_PROXY_URL=http://127.0.0.1:9000
# AGENT_TOOL_MODE=bridge
# QWEN_PRESERVE_THINKING=true
# QWEN_SESSION_CACHE=true
# Optional public SSE URL for AGENT_TOOL_MODE=remote_mcp:
# AEGIS_MCP_SSE_URL=https://your-tunnel.example/sse
