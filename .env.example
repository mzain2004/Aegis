# Network binding for the FastAPI service.
PROXY_HOST=0.0.0.0

# HTTP port exposed by uvicorn.
PROXY_PORT=9000

# Upstream Kubernetes MCP server URL used by the forwarder.
K8S_MCP_SERVER_URL=http://127.0.0.1:8000

# Shared secret reserved for future HMAC verification.
SHARED_HMAC_SECRET=development-shared-secret

# Nonce lifetime in seconds for future approval workflows.
NONCE_TTL=300

# Structured logging level.
LOG_LEVEL=INFO

# Deployment environment label.
ENVIRONMENT=development

# Path to the BPF-LSM kernel failsafe's plaintext audit log (read-only tail).
# FAILSAFE_AUDIT_LOG_PATH=/var/log/mcp-failsafe.log

# Transport backend the failsafe correlator delegates actual dispatch to.
# FAILSAFE_DELEGATE_BACKEND=kubernetes

# Cgroup id to filter failsafe block events by; 0 disables the filter.
# FAILSAFE_CGROUP_ID=0

# Downgrade a result to a 502 failure when the kernel blocked anything in-window.
# FAILSAFE_FAIL_ON_BLOCK=false
